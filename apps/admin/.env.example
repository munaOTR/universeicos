# Universe Admin App — Environment Variables Template
# Copy this file to .env.local for local dev, or .env.production for production.
# Never commit .env.local or .env.production to git.

# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── App Config ────────────────────────────────────────────────────────────────
# Local:      http://localhost:5174
# Production: https://admin.yourdomain.com
VITE_APP_URL=http://localhost:5174
VITE_APP_ENV=development

# ── Server-side secrets (NOT prefixed with VITE_) ─────────────────────────────
# These are never exposed to the browser. Used by Supabase Edge Functions only.
RESEND_API_KEY=re_your-resend-api-key

# ── Feature Flags ─────────────────────────────────────────────────────────────
# VITE_FEATURE_MARKETPLACE=false
