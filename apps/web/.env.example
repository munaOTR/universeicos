# Universe Web App — Environment Variables Template
# Copy this file to .env.local for local dev, or .env.production for production.
# Never commit .env.local or .env.production to git.

# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── App Config ────────────────────────────────────────────────────────────────
# Local:      http://localhost:5173
# Production: https://waitlist.universeicos.app
VITE_APP_URL=http://localhost:5173
VITE_APP_ENV=development

# ── Server-side secrets (NOT prefixed with VITE_) ─────────────────────────────
# These are never exposed to the browser. Used by Supabase Edge Functions only.
RESEND_API_KEY=re_your-resend-api-key
RESEND_WEBHOOK_SECRET=whsec_your-webhook-secret
DATABASE_PASSWORD=your-database-password

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Uncomment to enable features before they are released globally
# VITE_FEATURE_MARKETPLACE=false
