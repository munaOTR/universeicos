# ============================================================
# Universe Monorepo — Root .gitignore
# ============================================================

# ----------------------------------------------------------
# Dependencies
# ----------------------------------------------------------
node_modules/
.pnpm-store/
.yarn/
.npm/

# ----------------------------------------------------------
# Build & Output
# ----------------------------------------------------------
dist/
dist-ssr/
build/
out/
.output/
*.tsbuildinfo

# ----------------------------------------------------------
# Environment & Secrets
# ⚠️  NEVER commit real secrets. Use .env.example instead.
# ----------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.cert

# ----------------------------------------------------------
# Logs
# ----------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ----------------------------------------------------------
# Test & Coverage
# ----------------------------------------------------------
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/
playwright/.cache/

# ----------------------------------------------------------
# Cache & Temp
# ----------------------------------------------------------
.cache/
.turbo/
.eslintcache
.stylelintcache
.parcel-cache/
*.local
tmp/
temp/

# ----------------------------------------------------------
# OS Files
# ----------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ----------------------------------------------------------
# Editor & IDE
# ----------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
.project
.classpath
.settings/

# ----------------------------------------------------------
# Markdown — All docs consolidated into docs/
# README.md at root and .github/ templates are kept.
# ----------------------------------------------------------
*.md
!README.md
!.github/**/*.md
!docs/**/*.md
!docs/*.md

# ----------------------------------------------------------
# Supabase — local DB config, migrations & secrets
# ----------------------------------------------------------
supabase/
# Track edge functions source code (but not local/secrets)
!supabase/functions/
!supabase/functions/**
!supabase/migrations/
!supabase/migrations/**

# ----------------------------------------------------------
# Miscellaneous
# ----------------------------------------------------------
*.tgz
*.zip
*.tar.gz
code_dump.txt
